<% content_for :title, "Users - #{@organization.name}" %>

<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">Users</h1>
    <%= link_to "Invite User", new_organization_user_path(@organization),
                class: "btn btn-soft btn-primary" %>
  </div>

  <%= render(PaginatedListComponent.new(
    filter_url: organization_users_path(@organization),
    frame_id: "users_index_list",
    filter_param: "user_name",
    filter_placeholder: "Filter users by name or email...",
    current_filter: params[:user_name]
  )) do %>
    <%= render partial: "organizations/users/users_index_content",
              locals: { pagy_users: @pagy_users, users: @users, organization: @organization,
                        existing_role_keys_by_user: @existing_role_keys_by_user, teams: @teams } %>
  <% end %>
</div>
