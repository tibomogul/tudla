<%= tag.div id: dom_id(cycle), class: "card bg-base-100 shadow-sm" do %>
  <div class="card-body p-3 flex-row items-center justify-between">
    <div class="flex items-center gap-2">
      <%= link_to cycle.name, cycle_path(cycle), class: "font-medium hover:underline" %>
      <span class="badge badge-sm <%= cycle_badge_color(cycle.current_state) %>"><%= cycle.current_state.humanize %></span>
    </div>
    <span class="text-sm text-base-content/60">
      <%= cycle.start_date.strftime("%d %b") %> — <%= cycle.end_date.strftime("%d %b %Y") %>
    </span>
  </div>
<% end %>
