<%= form_with(model: cycle, class: "contents", data: { turbo: false, controller: "theme-dark" }) do |form| %>
  <% if cycle.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(cycle.errors.count, "error") %> prohibited this cycle from being saved:</h2>
      <ul class="list-disc ml-6">
        <% cycle.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cycle.errors[:name].none?, "border-red-400 focus:outline-red-600": cycle.errors[:name].any?}] %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div class="my-5">
      <%= form.label :start_date %>
      <%= form.date_field :start_date, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cycle.errors[:start_date].none?, "border-red-400 focus:outline-red-600": cycle.errors[:start_date].any?}] %>
    </div>

    <div class="my-5">
      <%= form.label :end_date %>
      <%= form.date_field :end_date, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cycle.errors[:end_date].none?, "border-red-400 focus:outline-red-600": cycle.errors[:end_date].any?}] %>
    </div>
  </div>

  <% if @organizations && @organizations.size > 1 %>
    <div class="my-5">
      <%= form.label :organization_id, "Organization" %>
      <%= form.collection_select :organization_id, @organizations, :id, :name,
          { prompt: "Select an organization" },
          class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": cycle.errors[:organization_id].none?, "border-red-400 focus:outline-red-600": cycle.errors[:organization_id].any?}] %>
    </div>
  <% elsif @organizations&.size == 1 %>
    <%= form.hidden_field :organization_id, value: @organizations.first.id %>
  <% end %>

  <div class="inline">
    <%= form.submit class: "btn btn-soft btn-primary" %>
  </div>
<% end %>
