<% if @update_context == "betting_table" %>
  <%= turbo_stream.replace dom_id(@pitch, :betting_card) do %>
    <%= render "cycles/betting_pitch_card", pitch: @pitch, cycle: @cycle, teams: @teams, betting_enabled: @betting_enabled %>
  <% end %>
<% else %>
  <%= turbo_stream.replace dom_id(@pitch) do %>
    <%= render "pitches/pitch", pitch: @pitch %>
  <% end %>
<% end %>
