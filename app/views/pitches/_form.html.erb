<%= form_with(model: pitch, class: "contents", data: { turbo: false, controller: "theme-dark" }) do |form| %>
  <% if pitch.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(pitch.errors.count, "error") %> prohibited this pitch from being saved:</h2>
      <ul class="list-disc ml-6">
        <% pitch.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title do %>
      Title <span class="text-error">*</span>
    <% end %>
    <%= form.text_field :title, required: true, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pitch.errors[:title].none?, "border-red-400 focus:outline-red-600": pitch.errors[:title].any?}] %>
  </div>

  <div class="my-5">
    <label class="label">Appetite <span class="text-error">*</span></label>
    <div class="flex gap-4 mt-2">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= form.radio_button :appetite, 2, class: "radio radio-primary", required: true %>
        <span>Small Batch (2 weeks)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <%= form.radio_button :appetite, 6, class: "radio radio-primary" %>
        <span>Big Batch (6 weeks)</span>
      </label>
    </div>
  </div>

  <% if @organizations && @organizations.size > 1 %>
    <div class="my-5">
      <%= form.label :organization_id do %>
        Organization <span class="text-error">*</span>
      <% end %>
      <%= form.collection_select :organization_id, @organizations, :id, :name,
          { prompt: "Select an organization" },
          class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pitch.errors[:organization_id].none?, "border-red-400 focus:outline-red-600": pitch.errors[:organization_id].any?}] %>
    </div>
  <% elsif @organizations&.size == 1 %>
    <%= form.hidden_field :organization_id, value: @organizations.first.id %>
  <% end %>

  <div class="divider"></div>

  <h3 class="font-semibold text-lg mb-1">Ingredients</h3>
  <p class="text-sm text-base-content/60 mb-4">The five components of a shaped pitch. Fill these out to make the pitch ready for the betting table.</p>

  <div class="flex flex-col gap-6">
    <div>
      <%= form.label :problem, "Problem — What's broken about the status quo?" %>
      <%= form.marksmith :problem, rows: 6, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pitch.errors[:problem].none?, "border-red-400 focus:outline-red-600": pitch.errors[:problem].any?}] %>
    </div>

    <div>
      <%= form.label :solution, "Solution — Breadboards and fat-marker sketches" %>
      <%= form.marksmith :solution, rows: 6, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pitch.errors[:solution].none?, "border-red-400 focus:outline-red-600": pitch.errors[:solution].any?}] %>
    </div>

    <div>
      <%= form.label :rabbit_holes, "Rabbit Holes — Known technical risks" %>
      <%= form.marksmith :rabbit_holes, rows: 6, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pitch.errors[:rabbit_holes].none?, "border-red-400 focus:outline-red-600": pitch.errors[:rabbit_holes].any?}] %>
    </div>

    <div>
      <%= form.label :no_gos, "No-Gos — Explicitly excluded scope" %>
      <%= form.marksmith :no_gos, rows: 6, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": pitch.errors[:no_gos].none?, "border-red-400 focus:outline-red-600": pitch.errors[:no_gos].any?}] %>
    </div>
  </div>

  <div class="inline">
    <%= form.submit class: "btn btn-soft btn-primary mt-6" %>
  </div>
<% end %>
