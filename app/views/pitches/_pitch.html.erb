<%= tag.div id: dom_id(pitch), class: "card bg-base-100 shadow-sm" do %>
  <div class="card-body p-3 flex-row items-center justify-between">
    <div class="flex items-center gap-2">
      <%= link_to pitch.title, pitch_path(pitch), class: "font-medium hover:underline" %>
      <span class="badge badge-sm <%= pitch_badge_color(pitch.current_state) %>"><%= pitch.current_state.humanize.titleize %></span>
      <span class="badge badge-sm badge-outline"><%= pitch.appetite_label %></span>
    </div>
    <span class="text-xs text-base-content/60">
      by <%= pitch.user&.preferred_name || pitch.user&.email %>
    </span>
  </div>
<% end %>
